# Copie este arquivo para ".env" e preencha com as credenciais do SEU projeto Supabase
# (Configurações do projeto -> API, dentro do supabase.com)

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica-aqui

# Service role key (Project Settings -> API -> Legacy anon, service_role keys)
# Só usada em funções serverless (pasta /api), NUNCA no client (ignora RLS por completo).
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-aqui

# Número de WhatsApp usado nos botões de contato/pedido (com DDI+DDD, só números)
VITE_WHATSAPP_NUMBER=5511976858856

# OpenRouteService — cálculo de distância/rota para o frete (cadastro gratuito em openrouteservice.org)
# Usada só no backend/serverless (pasta /api), nunca deve ter prefixo VITE_ nem ser exposta no client.
ORS_API_KEY=sua-chave-openrouteservice-aqui

# Endereço de origem da loja (lat/lng) para cálculo de frete — nunca exposto no site.
LOJA_ENDERECO_LAT=-23.5277
LOJA_ENDERECO_LNG=-46.9042

# Fórmula de precificação do frete (moto) — ajustável sem precisar mexer em código
FRETE_TAXA_BASE=5
FRETE_VALOR_POR_KM=1.5
FRETE_MINIMO=8
FRETE_RAIO_MAXIMO_KM=15
